---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Layout title={`${post.data.title} — Daan Rosendal`}>
  <nav class="mb-12 flex gap-6 text-sm">
    <a href="/" class="text-gray-500 hover:text-gray-900">Home</a>
    <a href="/blog" class="text-gray-500 hover:text-gray-900">Blog</a>
  </nav>

  <article>
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-3">{post.data.title}</h1>
      <p class="text-gray-500 mb-2">{post.data.description}</p>
      <time class="text-gray-400 text-sm">
        {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <div class="prose prose-gray max-w-none">
      <Content />
    </div>
  </article>
</Layout>

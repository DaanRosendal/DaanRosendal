---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Daan Rosendal">
  <header class="mb-12">
    <h1 class="text-4xl font-bold mb-2">Daan Rosendal</h1>
    <p class="text-gray-500">Software Engineer</p>
  </header>

  <nav class="mb-12 flex gap-6 text-sm">
    <a href="/" class="font-medium">Home</a>
    <a href="/blog" class="text-gray-500 hover:text-gray-900">Blog</a>
  </nav>

  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-4">About</h2>
    <p class="text-gray-700 leading-relaxed">
      Software engineer with experience in building reliable systems. Former intern at CERN.
    </p>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-4">Links</h2>
    <ul class="space-y-2 text-gray-700">
      <li><a href="https://linkedin.com/in/daanrosendal" class="text-blue-600 hover:underline">LinkedIn</a></li>
      <li><a href="mailto:daan.rosendal@alumni.cern" class="text-blue-600 hover:underline">Email</a></li>
      <li><a href="/blog" class="text-blue-600 hover:underline">Blog</a></li>
